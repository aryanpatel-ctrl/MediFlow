# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medqueue

# JWT
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+1234567890

# Vapi.ai (Voice - Optional)
VAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPI_BASE_URL=https://api.vapi.ai
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_ASSISTANT_ID=
VAPI_MODEL_NAME=gpt-4o-mini
VAPI_WEBHOOK_SECRET=your-shared-webhook-secret
APP_BASE_URL=https://your-public-api.example.com
SERVER_PUBLIC_URL=https://your-public-api.example.com
ENABLE_AI_REMINDER_CALLS=true
AI_CALL_CHECK_INTERVAL=1
AI_CALL_LOOKAHEAD_MINUTES=60
AI_CALL_WINDOW_MINUTES=5
AI_CALL_RETRY_MINUTES=15
AI_CALL_MAX_ATTEMPTS=2

# Google Calendar OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/hospitals/google/callback

# Encryption Key (for storing Google tokens securely)
ENCRYPTION_KEY=your-32-character-encryption-key!
